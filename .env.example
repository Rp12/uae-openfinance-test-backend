# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration (optional - keys will be read from files if not provided)
# PUBLIC_KEY=
# PRIVATE_KEY=

# Database Configuration (for production use)
# DATABASE_URL=postgresql://user:password@localhost:5432/insurance_sandbox

# Redis Configuration (for production use)
# REDIS_URL=redis://localhost:6379

# API Configuration
API_BASE_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
